<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram name="InsureMail AI Business Flow" id="insuremail-biz">
    <mxGraphModel dx="1200" dy="1060" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1060" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="title1" value="InsureMail AI" style="text;html=1;align=center;fontSize=28;fontStyle=1;fontColor=#1e3a5f;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="12" width="500" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="title2" value="Business Flow — From Inbox to Resolution" style="text;html=1;align=center;fontSize=14;fontColor=#64748b;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="48" width="600" height="24" as="geometry"/>
        </mxCell>

        <!-- CUSTOMER START -->
        <mxCell id="customer" value="&lt;b&gt;Customer Email&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:11px&apos;&gt;Insurance query received&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="480" y="85" width="240" height="65" as="geometry"/>
        </mxCell>

        <!-- Intent note -->
        <mxCell id="intent_note" value="&lt;b&gt;17 intent types:&lt;/b&gt;&lt;br&gt;coverage · claim submission · payment&lt;br&gt;renewal · cancellation · pre-auth&lt;br&gt;complaint · hospital query · broker..." style="text;html=1;align=left;fontSize=11;fontColor=#374151;strokeColor=#dae8fc;fillColor=#f0f7ff;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="748" y="85" width="215" height="65" as="geometry"/>
        </mxCell>

        <!-- Cost callout -->
        <mxCell id="cost_box" value="&lt;b style=&apos;color:#dc2626&apos;&gt;Manual:&lt;/b&gt; ~$2.00/email&lt;br&gt;&lt;b style=&apos;color:#16a34a&apos;&gt;AI:&lt;/b&gt; $0.006/email&lt;br&gt;&lt;b&gt;333× cheaper&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontSize=11;arcSize=10;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="40" y="185" width="125" height="65" as="geometry"/>
        </mxCell>

        <!-- Arrow: customer to platform -->
        <mxCell id="arr_cust_plat" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="customer" target="platform_bg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PLATFORM BG -->
        <mxCell id="platform_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7c3aed;strokeWidth=2;arcSize=4;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="175" y="180" width="855" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="platform_label" value="⚙  InsureMail AI Platform" style="text;html=1;align=center;fontSize=14;fontStyle=1;fontColor=#5b21b6;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="183" width="400" height="22" as="geometry"/>
        </mxCell>

        <!-- 5 pipeline steps -->
        <mxCell id="s1" value="&lt;b&gt;1. Parse &amp;amp; Redact&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:10px&apos;&gt;RFC 2822 · PII removed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="188" y="210" width="148" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;2. Classify Intent&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:10px&apos;&gt;Claude 3 Sonnet&lt;br&gt;17 categories&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="354" y="210" width="148" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;3. RAG Retrieval&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:10px&apos;&gt;HyDE · Titan V2&lt;br&gt;BM25 + RRF rerank&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="210" width="148" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="&lt;b&gt;4. CRM Validation&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:10px&apos;&gt;Policy · Eligibility&lt;br&gt;Fraud score&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="686" y="210" width="148" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="&lt;b&gt;5. Generate &amp;amp; Judge&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:10px&apos;&gt;Mistral 7B · Llama judge&lt;br&gt;8-dim quality eval&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="852" y="210" width="148" height="75" as="geometry"/>
        </mxCell>

        <!-- Step arrows -->
        <mxCell id="pa1" style="edgeStyle=none;strokeColor=#7c3aed;strokeWidth=1.5;" edge="1" source="s1" target="s2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa2" style="edgeStyle=none;strokeColor=#7c3aed;strokeWidth=1.5;" edge="1" source="s2" target="s3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa3" style="edgeStyle=none;strokeColor=#7c3aed;strokeWidth=1.5;" edge="1" source="s3" target="s4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa4" style="edgeStyle=none;strokeColor=#7c3aed;strokeWidth=1.5;" edge="1" source="s4" target="s5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Metrics strip -->
        <mxCell id="metrics_strip" value="$0.006 / email  ·  &lt;3 sec triage  ·  100% intent accuracy (live test)  ·  24/7 availability" style="text;html=1;align=center;fontSize=12;strokeColor=#e9d5ff;fillColor=#faf5ff;rounded=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="255" y="318" width="690" height="28" as="geometry"/>
        </mxCell>

        <!-- Arrow: metrics to diamond -->
        <mxCell id="arr_plat_dia" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#5b21b6;strokeWidth=2;" edge="1" source="metrics_strip" target="diamond" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CONFIDENCE DIAMOND -->
        <mxCell id="diamond" value="&lt;b&gt;Confidence Score?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="495" y="365" width="210" height="80" as="geometry"/>
        </mxCell>

        <!-- Diamond arrows -->
        <mxCell id="arr_auto" value="&lt;b&gt;≥ 0.8&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16a34a;strokeWidth=2;fontSize=12;fontColor=#16a34a;fontStyle=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="diamond" target="box_auto" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_human" value="&lt;b&gt;0.5–0.8&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d97706;strokeWidth=2;fontSize=12;fontColor=#d97706;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="diamond" target="box_human" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_esc" value="&lt;b&gt;&lt; 0.5&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#dc2626;strokeWidth=2;fontSize=12;fontColor=#dc2626;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="diamond" target="box_esc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- THREE PATH BOXES -->
        <mxCell id="box_auto" value="&lt;b style=&apos;font-size:13px&apos;&gt;AUTO RESPONSE&lt;/b&gt;&lt;br&gt;~68% of emails&lt;br&gt;&lt;font style=&apos;font-size:11px&apos;&gt;Sent instantly via Amazon SES&lt;br&gt;Zero human involvement&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontSize=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="65" y="490" width="235" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="box_human" value="&lt;b style=&apos;font-size:13px&apos;&gt;HUMAN REVIEW&lt;/b&gt;&lt;br&gt;~25% of emails&lt;br&gt;&lt;font style=&apos;font-size:11px&apos;&gt;AI draft → agent approves/edits&lt;br&gt;SLA: within 4 hours&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#d97706;strokeWidth=2;fontSize=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="483" y="490" width="235" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="box_esc" value="&lt;b style=&apos;font-size:13px&apos;&gt;ESCALATE&lt;/b&gt;&lt;br&gt;~7% of emails&lt;br&gt;&lt;font style=&apos;font-size:11px&apos;&gt;Full AI context to specialist&lt;br&gt;SLA: within 24 hours&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=2;fontSize=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="901" y="490" width="235" height="90" as="geometry"/>
        </mxCell>

        <!-- Outcome boxes -->
        <mxCell id="out_auto" value="&lt;font color=&apos;#14532d&apos;&gt;✓ Response in &lt;b&gt;&lt;3 seconds&lt;/b&gt;&lt;br&gt;✓ No agent cost&lt;br&gt;✓ Consistent AI quality&lt;/font&gt;" style="text;html=1;align=center;fontSize=11;strokeColor=#16a34a;fillColor=#f0fdf4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="65" y="600" width="235" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="out_human" value="&lt;font color=&apos;#78350f&apos;&gt;✓ AI handles research &amp;amp; drafting&lt;br&gt;✓ Agent adds human judgement&lt;br&gt;✓ Full audit trail maintained&lt;/font&gt;" style="text;html=1;align=center;fontSize=11;strokeColor=#d97706;fillColor=#fffbeb;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="483" y="600" width="235" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="out_esc" value="&lt;font color=&apos;#7f1d1d&apos;&gt;✓ Specialist gets full AI context&lt;br&gt;✓ Policy docs pre-retrieved&lt;br&gt;✓ CRM data pre-loaded&lt;/font&gt;" style="text;html=1;align=center;fontSize=11;strokeColor=#dc2626;fillColor=#fff5f5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="901" y="600" width="235" height="60" as="geometry"/>
        </mxCell>

        <!-- Outcome → resolution arrows -->
        <mxCell id="arr_a_res" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16a34a;strokeWidth=1.5;" edge="1" source="out_auto" target="resolution" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arr_h_res" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d97706;strokeWidth=1.5;" edge="1" source="out_human" target="resolution" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arr_e_res" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#dc2626;strokeWidth=1.5;" edge="1" source="out_esc" target="resolution" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- RESOLUTION -->
        <mxCell id="resolution" value="&lt;b&gt;Customer Issue Resolved&lt;/b&gt;&lt;br&gt;&lt;font style=&apos;font-size:11px&apos;&gt;Response delivered · Case closed&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="435" y="695" width="330" height="65" as="geometry"/>
        </mxCell>

        <!-- resolution → compliance -->
        <mxCell id="arr_res_comp" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=2;" edge="1" source="resolution" target="compliance" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- COMPLIANCE FOOTER -->
        <mxCell id="compliance" value="Every email — regardless of path:  ✓ Logged to DynamoDB (full audit)  ·  ✓ PII redacted before processing  ·  ✓ GDPR compliant  ·  ✓ CloudWatch metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#1e40af;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="185" y="795" width="830" height="48" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
