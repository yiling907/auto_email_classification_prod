{
  "Comment": "InsureMail AI - Email Processing Workflow",
  "StartAt": "ParseEmail",
  "States": {
    "ParseEmail": {
      "Type": "Task",
      "Resource": "${email_parser_lambda_arn}",
      "Comment": "Parse raw email, extract fields, and run Textract + Bedrock entity extraction",
      "ResultPath": "$.parsed_email",
      "Next": "ClassifyIntent",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "HandleError",
          "ResultPath": "$.error"
        }
      ]
    },
    "ClassifyIntent": {
      "Type": "Parallel",
      "Comment": "Run LLM and BioBERT intent classifiers in parallel",
      "Branches": [
        {
          "StartAt": "ClassifyIntentByLLM",
          "States": {
            "ClassifyIntentByLLM": {
              "Type": "Task",
              "Resource": "${classify_intent_by_llm_lambda_arn}",
              "Comment": "Classify email intent using Mistral/Llama LLM via Bedrock",
              "Parameters": {
                "email_id.$":   "$.parsed_email.email_id",
                "email_body.$": "$.parsed_email.parsed_data.body_text",
                "subject.$":    "$.parsed_email.parsed_data.subject"
              },
              "ResultPath": "$.llm_result",
              "End": true
            }
          }
        },
        {
          "StartAt": "ClassifyIntentByBioBERT",
          "States": {
            "ClassifyIntentByBioBERT": {
              "Type": "Task",
              "Resource": "${classify_intent_by_biobert_lambda_arn}",
              "Comment": "Classify email intent using fine-tuned BioBERT on SageMaker",
              "Parameters": {
                "email_id.$":   "$.parsed_email.email_id",
                "email_body.$": "$.parsed_email.parsed_data.body_text",
                "subject.$":    "$.parsed_email.parsed_data.subject"
              },
              "ResultPath": "$.biobert_result",
              "End": true,
              "Catch": [
                {
                  "ErrorEquals": ["States.ALL"],
                  "Comment": "Fall back to empty result if BioBERT endpoint unavailable",
                  "ResultPath": "$.biobert_error",
                  "Next": "FallbackBioBERT"
                }
              ]
            },
            "FallbackBioBERT": {
              "Type": "Pass",
              "Comment": "BioBERT unavailable — return null classification so LLM result is used",
              "Parameters": {
                "classification": null,
                "confidence":     0.0,
                "model":          "biobert_unavailable"
              },
              "ResultPath": "$.biobert_result",
              "End": true
            }
          }
        }
      ],
      "ResultPath": "$.classifiers",
      "Next": "RetrieveKnowledge",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "HandleError",
          "ResultPath": "$.error"
        }
      ]
    },
    "RetrieveKnowledge": {
      "Type": "Task",
      "Resource": "${rag_retrieval_lambda_arn}",
      "Comment": "Retrieve relevant knowledge base documents",
      "Parameters": {
        "email_text.$": "$.parsed_email.parsed_data.body_text",
        "intent.$":     "$.classifiers[0].llm_result.classification.customer_intent",
        "top_k": 5
      },
      "ResultPath": "$.rag_results",
      "Next": "ValidateCRM",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "SetEmptyRAG",
          "ResultPath": "$.rag_error"
        }
      ]
    },
    "SetEmptyRAG": {
      "Type": "Pass",
      "Comment": "RAG retrieval failed — use empty doc list so pipeline continues",
      "Parameters": {
        "retrieved_documents": [],
        "statusCode": 200
      },
      "ResultPath": "$.rag_results",
      "Next": "ValidateCRM"
    },
    "ValidateCRM": {
      "Type": "Task",
      "Resource": "${crm_validation_lambda_arn}",
      "Comment": "CRM validation: Text-to-SQL (Mistral 7B) → DynamoDB customer lookup → policy eligibility check",
      "Parameters": {
        "email_id.$":    "$.parsed_email.email_id",
        "intent.$":      "$.classifiers[0].llm_result.classification.customer_intent",
        "email_body.$":  "$.parsed_email.parsed_data.body_text",
        "extracted_entities": {
          "policy_number.$": "$.parsed_email.parsed_data.policy_number",
          "member_id.$":     "$.parsed_email.parsed_data.member_id",
          "customer_id.$":   "$.parsed_email.parsed_data.customer_id"
        }
      },
      "ResultPath": "$.crm_validation",
      "Next": "AssessFraudRisk",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "SetEmptyCRM",
          "ResultPath": "$.crm_error"
        }
      ]
    },
    "SetEmptyCRM": {
      "Type": "Pass",
      "Comment": "CRM lookup failed — continue pipeline with empty CRM context",
      "Parameters": {
        "crm_found": false,
        "customer": null,
        "policy": null,
        "validation": {
          "policy_exists": false,
          "eligible_for_intent": false,
          "ineligibility_reason": "CRM lookup failed"
        }
      },
      "ResultPath": "$.crm_validation",
      "Next": "AssessFraudRisk"
    },
    "AssessFraudRisk": {
      "Type": "Pass",
      "Comment": "Rule-based fraud risk assessment",
      "Parameters": {
        "risk_level": "low",
        "risk_score": 0.15,
        "flags": []
      },
      "ResultPath": "$.fraud_score",
      "Next": "GenerateResponse"
    },
    "GenerateResponse": {
      "Type": "Task",
      "Resource": "${llm_response_lambda_arn}",
      "Comment": "Generate response using Claude 3",
      "Parameters": {
        "email_id.$":        "$.parsed_email.email_id",
        "email_body.$":      "$.parsed_email.parsed_data.body_text",
        "subject.$":         "$.parsed_email.parsed_data.subject",
        "classification.$":  "$.classifiers[0].llm_result.classification",
        "rag_documents.$":   "$.rag_results.retrieved_documents",
        "crm_validation.$":  "$.crm_validation",
        "fraud_score.$":     "$.fraud_score"
      },
      "ResultPath": "$.response",
      "Next": "DetermineAction",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "HandleError",
          "ResultPath": "$.error"
        }
      ]
    },
    "DetermineAction": {
      "Type": "Choice",
      "Comment": "Route based on confidence score",
      "Choices": [
        {
          "Variable": "$.response.action",
          "StringEquals": "auto_response",
          "Next": "AutoRespond"
        },
        {
          "Variable": "$.response.action",
          "StringEquals": "human_review",
          "Next": "QueueForReview"
        }
      ],
      "Default": "Escalate"
    },
    "AutoRespond": {
      "Type": "Task",
      "Resource": "${email_sender_lambda_arn}",
      "Comment": "Send auto-response via SES",
      "Parameters": {
        "email_id.$":         "$.parsed_email.email_id",
        "recipient_email.$":  "$.parsed_email.parsed_data.sender_email",
        "subject.$":          "$.parsed_email.parsed_data.subject",
        "response_text.$":    "$.response.response_text",
        "confidence_score.$": "$.response.confidence_score",
        "reference_ids.$":    "$.response.reference_ids"
      },
      "ResultPath": "$.email_result",
      "Next": "SaveResult",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.email_error",
          "Next": "SaveResult"
        }
      ]
    },
    "QueueForReview": {
      "Type": "Pass",
      "Comment": "Queue for human review",
      "Parameters": {
        "action": "queued_for_review",
        "message": "Queued for human review"
      },
      "ResultPath": "$.final_action",
      "Next": "SaveResult"
    },
    "Escalate": {
      "Type": "Pass",
      "Comment": "Escalate to agent",
      "Parameters": {
        "action": "escalated",
        "message": "Escalated to human agent"
      },
      "ResultPath": "$.final_action",
      "Next": "SaveResult"
    },
    "HandleError": {
      "Type": "Pass",
      "Comment": "Handle errors and escalate",
      "Parameters": {
        "action": "error_escalation",
        "message": "Error occurred, escalating to human agent"
      },
      "ResultPath": "$.final_action",
      "Next": "SaveResult"
    },
    "SaveResult": {
      "Type": "Task",
      "Resource": "${save_result_lambda_arn}",
      "Comment": "Persist aggregated pipeline result to pipeline_results DynamoDB",
      "Next": "Success",
      "ResultPath": "$.save_result",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.save_result_error",
          "Next": "Success"
        }
      ]
    },
    "Success": {
      "Type": "Succeed",
      "Comment": "Workflow completed successfully"
    }
  }
}
