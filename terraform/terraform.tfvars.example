# Example Terraform Variables File for InsureMail AI
# Copy this to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git (it contains sensitive credentials)

# Project Configuration
project_name = "insuremail-ai"
environment  = "dev"
aws_region   = "us-east-1"

# SES Configuration (for sending responses)
sender_email = "your-verified-email@gmail.com"  # Must be verified in SES
sender_name  = "InsureMail AI Support"

# Gmail IMAP Configuration (for receiving emails)
# REQUIRED: Generate App Password at https://myaccount.google.com/apppasswords
gmail_address      = "your-email@gmail.com"
gmail_app_password = "xxxx xxxx xxxx xxxx"  # 16-character App Password (NOT your Gmail password)
imap_server        = "imap.gmail.com"
mark_emails_as_read = true

# Optional: Polling interval
imap_poll_interval_minutes = 5  # Check Gmail every 5 minutes

# Tags (optional)
tags = {
  Project     = "InsureMail AI"
  Environment = "Development"
  ManagedBy   = "Terraform"
}
