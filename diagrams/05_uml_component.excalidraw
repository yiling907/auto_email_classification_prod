{"type":"excalidraw","version":2,"source":"https://excalidraw.com","elements":[{"type":"text","id":"comp_title","x":80,"y":12,"width":1440,"height":34,"text":"InsureMail AI \u2014 UML Component Diagram","originalText":"InsureMail AI \u2014 UML Component Diagram","fontSize":22,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50001,"version":1,"versionNonce":50002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},{"type":"text","id":"comp_sub","x":80,"y":48,"width":1440,"height":20,"text":"Logical component structure showing deployable units, provided interfaces (\u2500\u25cb), required interfaces (\u2500\u25c1), and dependencies","originalText":"Logical component structure showing deployable units, provided interfaces (\u2500\u25cb), required interfaces (\u2500\u25c1), and dependencies","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50003,"version":1,"versionNonce":50004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},{"type":"rectangle","id":"comp_ingest","x":40,"y":150,"width":240,"height":160,"strokeColor":"#1e3a5f","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50010,"version":1,"versionNonce":50011,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"comp_ingest_t","x":44,"y":158,"width":232,"height":144,"text":"<<component>>\nEmailIngestion\n\n\u2022 GmailIMAPPoller\n  [Lambda, polls every\n   60s via EventBridge]\n\u2022 S3 Email Storage\n  [raw MIME emails]","originalText":"<<component>>\nEmailIngestion\n\n\u2022 GmailIMAPPoller\n  [Lambda, polls every\n   60s via EventBridge]\n\u2022 S3 Email Storage\n  [raw MIME emails]","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50012,"version":1,"versionNonce":50013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},{"type":"rectangle","id":"comp_pipeline","x":360,"y":120,"width":680,"height":220,"strokeColor":"#1e3a5f","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50020,"version":1,"versionNonce":50021,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"comp_pipeline_t","x":364,"y":128,"width":672,"height":204,"text":"<<component>>\nProcessingPipeline [AWS Step Functions + 6 Lambda Functions]\n\n  [Step 1] email_parser: RFC2822 parse, PII redact, attachment extract (14 categories)\n  [Step 2] classify_intent: Claude 3 Sonnet \u2192 17 intents \u2192 12 teams via INTENT_TO_ROUTE\n  [Step 3] rag_retrieval: HyDE (Haiku) + BM25 + Titan V2 (1024-dim) + RRF fusion + rerank\n  [Step 4] crm_validation: Mistral Text-to-SQL \u2192 DynamoDB customers lookup + eligibility\n  [Step 5] claude_response: Mistral 7B generation + 8-dimension quality evaluation judge\n  [Step 6] email_sender: 3-tier routing (auto\u22650.8 / human_review 0.5\u20130.8 / escalate<0.5)","originalText":"<<component>>\nProcessingPipeline [AWS Step Functions + 6 Lambda Functions]\n\n  [Step 1] email_parser: RFC2822 parse, PII redact, attachment extract (14 categories)\n  [Step 2] classify_intent: Claude 3 Sonnet \u2192 17 intents \u2192 12 teams via INTENT_TO_ROUTE\n  [Step 3] rag_retrieval: HyDE (Haiku) + BM25 + Titan V2 (1024-dim) + RRF fusion + rerank\n  [Step 4] crm_validation: Mistral Text-to-SQL \u2192 DynamoDB customers lookup + eligibility\n  [Step 5] claude_response: Mistral 7B generation + 8-dimension quality evaluation judge\n  [Step 6] email_sender: 3-tier routing (auto\u22650.8 / human_review 0.5\u20130.8 / escalate<0.5)","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50022,"version":1,"versionNonce":50023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},{"type":"rectangle","id":"comp_ai","x":1100,"y":120,"width":300,"height":220,"strokeColor":"#6d28d9","backgroundColor":"#ede9fe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50030,"version":1,"versionNonce":50031,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"comp_ai_t","x":1104,"y":128,"width":292,"height":204,"text":"<<component>>\nAIServices [AWS Bedrock]\n\n\u2022 Claude 3 Sonnet\n  Intent classification (Step 2)\n\u2022 Claude 3 Haiku\n  HyDE + cross-encoder rerank\n\u2022 Mistral 7B Instruct\n  CRM Text-to-SQL + response gen\n\u2022 Titan Embeddings V2\n  1024-dim vector embeddings\n\u2022 Llama 3.1 8B (fallback)","originalText":"<<component>>\nAIServices [AWS Bedrock]\n\n\u2022 Claude 3 Sonnet\n  Intent classification (Step 2)\n\u2022 Claude 3 Haiku\n  HyDE + cross-encoder rerank\n\u2022 Mistral 7B Instruct\n  CRM Text-to-SQL + response gen\n\u2022 Titan Embeddings V2\n  1024-dim vector embeddings\n\u2022 Llama 3.1 8B (fallback)","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50032,"version":1,"versionNonce":50033,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},{"type":"rectangle","id":"comp_data","x":360,"y":420,"width":500,"height":220,"strokeColor":"#c2410c","backgroundColor":"#fff7ed","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50040,"version":1,"versionNonce":50041,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"comp_data_t","x":364,"y":428,"width":492,"height":204,"text":"<<component>>\nDataStore [AWS DynamoDB + S3]\n\n\u2022 email_processing    PK: email_id (UUID) \u2014 pipeline state, results\n\u2022 kb_embeddings       PK: doc_id \u2014 1024-dim vectors, md5_hash\n\u2022 customers           PK: customer_id \u2014 policy, eligibility\n\u2022 model_metrics       PK: task_type, SK: model_id#ts\n\u2022 S3 Email Bucket     raw MIME + attachments\n\u2022 S3 Dashboard Bucket React SPA static assets","originalText":"<<component>>\nDataStore [AWS DynamoDB + S3]\n\n\u2022 email_processing    PK: email_id (UUID) \u2014 pipeline state, results\n\u2022 kb_embeddings       PK: doc_id \u2014 1024-dim vectors, md5_hash\n\u2022 customers           PK: customer_id \u2014 policy, eligibility\n\u2022 model_metrics       PK: task_type, SK: model_id#ts\n\u2022 S3 Email Bucket     raw MIME + attachments\n\u2022 S3 Dashboard Bucket React SPA static assets","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50042,"version":1,"versionNonce":50043,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},{"type":"rectangle","id":"comp_notify","x":920,"y":420,"wid