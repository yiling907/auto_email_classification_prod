    {"type":"text","id":"dl_sender_t","x":1714,"y":128,"width":222,"height":164,"text":"email_sender\n[Lambda + SES]\n─────────────\nIN: response + confidence\nOUT: email delivered\n\nRouting by confidence:\n≥ 0.8 → auto_response\n0.5–0.8 → human_review\n< 0.5 → escalate\n\nDelivers via Amazon SES","originalText":"email_sender\n[Lambda + SES]\n─────────────\nIN: response + confidence\nOUT: email delivered\n\nRouting by confidence:\n≥ 0.8 → auto_response\n0.5–0.8 → human_review\n< 0.5 → escalate\n\nDelivers via Amazon SES","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":90162,"version":1,"versionNonce":90163,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"dl_sender","lineHeight":1.25},

